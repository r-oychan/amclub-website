# Template for seed-script env files.
#
# Per-environment files (all gitignored — .env.* pattern):
#   cms/.env.seed.dev    ← used by `node scripts/seed-X.mjs --env=dev`
#   cms/.env.seed.uat    ← used by `--env=uat`
#   cms/.env.seed.prod   ← used by `--env=prod`
#
# Fallback file (legacy, single-env workflow):
#   cms/.env.seed        ← used when no --env flag and no SEED_ENV var
#
# Alternative to --env flag:
#   SEED_ENV=prod node scripts/seed-home-page.mjs
#
# Copy this file to the per-env name you need, then fill in real values.

# Deployed Strapi base URL (no trailing slash). Use the public-facing domain
# once it's wired (e.g., https://amclub.org.sg) or the Azure-generated FQDN
# during initial bring-up.
STRAPI_BASE_URL=https://amclub.org.sg

# Generate at /admin → Settings → API Tokens → Create new
#   (Full access, Unlimited duration)
STRAPI_API_TOKEN=
