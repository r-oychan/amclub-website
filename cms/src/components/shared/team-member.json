{
  "collectionName": "components_shared_team_members",
  "info": {
    "displayName": "Team Member",
    "icon": "user",
    "description": "Person tile with avatar + optional bio modal image"
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "role": {
      "type": "string"
    },
    "bio": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "bioImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "imageOffsetX": {
      "type": "decimal",
      "default": 50,
      "min": 0,
      "max": 100
    },
    "imageOffsetY": {
      "type": "decimal",
      "default": 50,
      "min": 0,
      "max": 100
    },
    "imageZoom": {
      "type": "decimal",
      "default": 1,
      "min": 0.5,
      "max": 4
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
