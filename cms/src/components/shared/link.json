{
  "collectionName": "components_shared_links",
  "info": {
    "displayName": "Link",
    "icon": "link",
    "description": "Button or CTA link with optional caption"
  },
  "attributes": {
    "label": {
      "type": "string",
      "required": true
    },
    "href": {
      "type": "string"
    },
    "caption": {
      "type": "string"
    },
    "isExternal": {
      "type": "boolean",
      "default": false
    },
    "variant": {
      "type": "enumeration",
      "enum": ["primary", "secondary", "outline", "text"],
      "default": "primary"
    }
  }
}
