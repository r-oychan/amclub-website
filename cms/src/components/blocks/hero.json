{
  "collectionName": "components_blocks_heroes",
  "info": {
    "displayName": "Hero",
    "icon": "picture",
    "description": "Hero banner with heading, subheading, background image and CTA"
  },
  "attributes": {
    "heading": {
      "type": "string",
      "required": true
    },
    "subheading": {
      "type": "text"
    },
    "backgroundImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "cta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.link"
    },
    "slides": { "type": "component", "repeatable": true, "component": "shared.hero-slide" },
    "variant": { "type": "enumeration", "enum": ["full", "compact"], "default": "full" },
    "autoPlayInterval": { "type": "integer", "default": 5000 }
  }
}
