{
  "kind": "collectionType",
  "collectionName": "facilities",
  "info": {
    "singularName": "facility",
    "pluralName": "facilities",
    "displayName": "Facility",
    "description": "Club facilities (fitness, kids, event spaces)"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "category": {
      "type": "enumeration",
      "enum": ["fitness", "kids", "event-space"],
      "required": true
    },
    "categoryLabel": {
      "type": "string"
    },
    "categoryIconSlug": {
      "type": "string"
    },
    "dressCode": {
      "type": "string"
    },
    "capacity": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "ctas": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link",
      "max": 3
    },
    "openingHours": {
      "type": "blocks"
    },
    "operatingHoursSections": {
      "type": "component",
      "repeatable": true,
      "component": "blocks.operating-hours-section"
    },
    "locationContact": {
      "type": "component",
      "repeatable": false,
      "component": "blocks.location-contact"
    },
    "locationLevel": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "detailedDescription": {
      "type": "blocks"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
