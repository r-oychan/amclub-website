      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "string"
    },
    "hero": {
      "type": "component",
      "repeatable": false,
      "component": "blocks.hero"
    },
    "promotionsHeading": {
      "type": "string",
      "default": "Available Promotions"
    },
    "promotionsIntro": {
      "type": "text"
    },
    "finalCta": {
      "type": "component",
      "repeatable": false,
      "component": "blocks.cta-banner"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
