{
  "kind": "collectionType",
  "collectionName": "testimonials",
  "info": {
    "singularName": "testimonial",
    "pluralName": "testimonials",
    "displayName": "Testimonial",
    "description": "Member testimonials with video"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "memberName": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "memberName",
      "required": true
    },
    "quote": {
      "type": "text",
      "required": true
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "videoUrl": {
      "type": "string"
    },
    "ctaLabel": {
      "type": "string"
    },
    "ctaUrl": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
