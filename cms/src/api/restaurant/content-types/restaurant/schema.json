{
  "kind": "collectionType",
  "collectionName": "restaurants",
  "info": {
    "singularName": "restaurant",
    "pluralName": "restaurants",
    "displayName": "Restaurant",
    "description": "Dining venues and retail outlets"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "cuisineType": {
      "type": "string"
    },
    "dressCode": {
      "type": "string"
    },
    "smartCasual": {
      "type": "boolean",
      "default": false
    },
    "description": {
      "type": "text",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "cuisineIconSlug": {
      "type": "string"
    },
    "menuUrl": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "ctas": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link",
      "max": 3
    },
    "openingHours": {
      "type": "blocks"
    },
    "operatingHoursSections": {
      "type": "component",
      "repeatable": true,
      "component": "blocks.operating-hours-section"
    },
    "locationContact": {
      "type": "component",
      "repeatable": false,
      "component": "blocks.location-contact"
    },
    "locationLevel": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "detailedDescription": {
      "type": "blocks"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "bottomCtas": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link",
      "max": 4
    },
    "body": {
      "type": "dynamiczone",
      "components": [
        "blocks.text-block",
        "blocks.card-grid",
        "blocks.feature-grid",
        "blocks.three-col-grid",
        "blocks.cta-banner",
        "blocks.faq-section",
        "blocks.downloads-section",
        "blocks.tabs-section",
        "blocks.team-grid",
        "blocks.image-panel-slideshow",
        "blocks.priced-card-grid",
        "blocks.quotes-block",
        "blocks.collage-gallery"
      ]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
