{
  "kind": "collectionType",
  "collectionName": "restaurants",
  "info": {
    "singularName": "restaurant",
    "pluralName": "restaurants",
    "displayName": "Restaurant",
    "description": "Dining venues and retail outlets"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "cuisineType": {
      "type": "string"
    },
    "dressCode": {
      "type": "string"
    },
    "description": {
      "type": "text",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "menuUrl": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "ctas": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link"
    },
    "openingHours": {
      "type": "blocks"
    },
    "locationLevel": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "detailedDescription": {
      "type": "blocks"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
