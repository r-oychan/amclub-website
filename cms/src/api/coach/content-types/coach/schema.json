{
  "kind": "collectionType",
  "collectionName": "coaches",
  "info": {
    "singularName": "coach",
    "pluralName": "coaches",
    "displayName": "Coach",
    "description": "Coach detail entries linked from facility team grids"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "role": {
      "type": "string",
      "required": true
    },
    "section": {
      "type": "enumeration",
      "enum": ["aquatics", "tennis", "squash", "gym", "pilates", "kids", "other"],
      "required": true
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "bio": {
      "type": "text"
    },
    "expertise": {
      "type": "text"
    },
    "qualifications": {
      "type": "text"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
