{
  "kind": "collectionType",
  "collectionName": "fitness_facilities",
  "info": {
    "singularName": "fitness-facility",
    "pluralName": "fitness-facilities",
    "displayName": "Fitness Facility",
    "description": "Fitness section detail pages: gym, aquatics, tennis, squash, pilates, etc. Self-relation `parent` lets nested programs (e.g. aquatics → swimamerica) live as child entries."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "name", "required": true },
    "shortDescription": { "type": "text" },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "heroVideo": { "type": "string" },
    "parentLabel": { "type": "string" },
    "parentHref": { "type": "string" },
    "locationLevel": { "type": "string" },
    "phone": { "type": "string" },
    "email": { "type": "email" },
    "dressCode": { "type": "string" },
    "teamHeading": { "type": "string" },
    "teamMembers": {
      "type": "component",
      "repeatable": true,
      "component": "shared.team-member"
    },
    "downloads": {
      "type": "component",
      "repeatable": false,
      "component": "blocks.downloads-section"
    },
    "operatingHoursSections": {
      "type": "component",
      "repeatable": true,
      "component": "blocks.operating-hours-section"
    },
    "locationContact": {
      "type": "component",
      "repeatable": false,
      "component": "blocks.location-contact"
    },
    "ctas": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link",
      "max": 4
    },
    "bottomCtas": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link",
      "max": 4
    },
    "body": {
      "type": "dynamiczone",
      "components": [
        "blocks.text-block",
        "blocks.card-grid",
        "blocks.feature-grid",
        "blocks.three-col-grid",
        "blocks.cta-banner",
        "blocks.faq-section",
        "blocks.downloads-section",
        "blocks.tabs-section",
        "blocks.party-packages",
        "blocks.team-grid",
        "blocks.image-panel-slideshow",
        "blocks.priced-card-grid",
        "blocks.quotes-block",
        "blocks.collage-gallery"
      ]
    },
    "order": { "type": "integer", "default": 0 },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::fitness-facility.fitness-facility",
      "inversedBy": "children"
    },
    "children": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::fitness-facility.fitness-facility",
      "mappedBy": "parent"
    },
    "coaches": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::coach.coach"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
