{
  "kind": "collectionType",
  "collectionName": "faq_categories",
  "info": {
    "singularName": "faq-category",
    "pluralName": "faq-categories",
    "displayName": "FAQ Category",
    "description": "Groups for FAQ items (Membership, Facilities, Dining, etc.)"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "displayOrder": {
      "type": "integer",
      "default": 0
    },
    "faqItems": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::faq-item.faq-item",
      "mappedBy": "faqCategory"
    }
  }
}
