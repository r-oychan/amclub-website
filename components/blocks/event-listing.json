{
  "collectionName": "components_blocks_event_listings",
  "info": {
    "displayName": "Event Listing",
    "icon": "calendar",
    "description": "Section displaying events from the Event collection"
  },
  "attributes": {
    "label": {
      "type": "string"
    },
    "heading": {
      "type": "string"
    },
    "cta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.link"
    },
    "maxItems": {
      "type": "integer",
      "default": 9
    },
    "filterByCategory": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::event-category.event-category"
    }
  }
}
